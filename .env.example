DATABASE_URL=mysql://koinonia:koinonia@localhost:3306/koinonia
AUTH_SECRET=your-secret
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SUPER_ADMIN_EMAILS=admin@example.com
AUTH_TRUST_HOST=                          # true si derriere un reverse proxy (Traefik, nginx)
PORT=3000
CRON_SECRET=                              # secret pour proteger les routes /api/cron/* (generer avec openssl rand -base64 32)

# ─── Backup S3 ───
S3_ENDPOINT=                              # endpoint S3-compatible (ex: https://s3.fr-par.scw.cloud)
S3_REGION=                                # region S3 (ex: fr-par)
S3_BUCKET=                                # nom du bucket (ex: koinonia-backups)
S3_ACCESS_KEY_ID=                         # cle d'acces S3
S3_SECRET_ACCESS_KEY=                     # secret S3
BACKUP_RETENTION_DAYS=30                  # nombre de jours de retention des backups (defaut: 30)
