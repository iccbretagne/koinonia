DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/koinonia
AUTH_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SUPER_ADMIN_EMAILS=admin@example.com
AUTH_TRUST_HOST=                          # true si derriere un reverse proxy (Traefik, nginx)
PORT=3000
CRON_SECRET=                              # secret pour proteger les routes /api/cron/* (generer avec openssl rand -base64 32)

# ─── S3 (backups BDD + fichiers media) ───
# Un seul bucket suffit — les prefixes separent les données :
#   backups/{timestamp}/db.sql.gz
#   media-events/{id}/photos/...
#   media-projects/{id}/files/...
# En production, un bucket dedié aux médias (S3_MEDIA_BUCKET) est recommande
# pour appliquer des regles de retention differentes (backups: 30j, medias: indefini).
S3_ENDPOINT=                              # endpoint S3-compatible (ex: https://s3.fr-par.scw.cloud)
S3_REGION=                                # region S3 (ex: fr-par)
S3_BUCKET=                                # nom du bucket (ex: koinonia-storage)
S3_ACCESS_KEY_ID=                         # cle d'acces S3
S3_SECRET_ACCESS_KEY=                     # secret S3
BACKUP_RETENTION_DAYS=30                  # nombre de jours de retention des backups (defaut: 30)

# ─── SMTP (emails de rappel) ───
SMTP_HOST=                                # serveur SMTP (ex: smtp.gmail.com, mail.votre-domaine.com)
SMTP_PORT=587                             # port SMTP (587 STARTTLS, 465 SSL, 25 sans auth)
SMTP_SECURE=false                         # true pour SSL/TLS natif (port 465)
SMTP_USER=                                # utilisateur SMTP (laisser vide si pas d'auth)
SMTP_PASS=                                # mot de passe SMTP
SMTP_FROM=Koinonia <noreply@votre-domaine.com>  # adresse expediteur
